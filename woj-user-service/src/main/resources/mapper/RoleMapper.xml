<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chuan.wojuserservice.mapper.RoleMapper">

    <resultMap id="BaseResultMap" type="com.chuan.wojmodel.pojo.entity.Role">
        <id property="id" column="id" jdbcType="TINYINT"/>
        <result property="role" column="role" jdbcType="VARCHAR"/>
        <result property="description" column="description" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="TINYINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,role,description,
        status,createTime,updateTime
    </sql>

    <select id="SelectRoleByUserAccount" resultType="java.lang.String">
        select role from `role` where id in (select role_id from `user_role` where uid = (select id from `user` where account = #{account}))
    </select>
</mapper>
